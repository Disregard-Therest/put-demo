{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Демо (Chrome, debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome"
    },
    {
      "name": "Демо (Chrome, release)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "flutterMode": "release"
    },
    {
      "name": "Демо (web-server: открыть в любом браузере)",
      "request": "launch",
      "type": "dart",
      "deviceId": "web-server",
      "args": ["--web-port", "8077"]
    }
  ]
}
